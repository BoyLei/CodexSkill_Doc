{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File with Arguments",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "args": "${command:pickArgs}"
        },
        {
            "name": "sync_codex_thread_provider.py (--self-test)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/codex_start_tools/sync_codex_thread_provider.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--self-test"
            ]
        },
        {
            "name": "sync_codex_thread_provider.py (--apply)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/codex_start_tools/sync_codex_thread_provider.py",
            "cwd": "${workspaceFolder}",
            "console": "integratedTerminal",
            "justMyCode": true,
            "args": [
                "--apply"
            ]
        },
        {
            "name": "Attach Python (127.0.0.1:5678)",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "127.0.0.1",
                "port": 5678
            },
            "justMyCode": true
        }
    ]
}